{
  "globs": [
    "**/*.md",
    "!**/node_modules/**",
    "!**/.venv/**",
    "!**/.next/**",
    "!**/.pytest_cache/**"
  ],
  "config": {
    "default": true,
    "MD013": false,
    "MD024": {
      "siblings_only": true
    },
    "MD033": false,
    "MD046": {
      "style": "fenced"
    }
  }
}
